---
import EmailIcon from "@icons/EmailIcon.astro";
import GithubIcon from "@icons/GithubIcon.astro";
import LinkedInIcon from "@icons/LinkedInIcon.astro";

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gray-200 dark:border-neutral-700">
  <div class="mx-auto max-w-2xl px-4 py-8">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-between">
      <p class="text-sm text-gray-500 dark:text-neutral-400">
        &copy; {year} Joe Manuola. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="mailto:joe@manuola.com"
          aria-label="Email"
          class="text-gray-400 transition-colors hover:text-gray-700 dark:text-neutral-500 dark:hover:text-neutral-200"
        >
          <EmailIcon size={20} title="Email" />
        </a>
        <a
          href="https://linkedin.com/in/joemanuola"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-gray-400 transition-colors hover:text-gray-700 dark:text-neutral-500 dark:hover:text-neutral-200"
        >
          <LinkedInIcon size={20} title="LinkedIn" />
        </a>
        <a
          href="https://github.com/PushLimits"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-gray-400 transition-colors hover:text-gray-700 dark:text-neutral-500 dark:hover:text-neutral-200"
        >
          <GithubIcon size={20} title="GitHub" />
        </a>
      </div>
    </div>
  </div>
</footer>
