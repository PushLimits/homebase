---
import BaseLayout from "src/layouts/BaseLayout.astro";
import Timeline from "@components/shared/Timeline.astro";
import Cards from "@components/shared/UserDetails.astro";
import EmailIcon from "@icons/EmailIcon.astro";
import LinkedInIcon from "@icons/LinkedInIcon.astro";
import GithubIcon from "@icons/GithubIcon.astro";

import { timelineEntries } from "@data/timeline";
---

<BaseLayout
  title="About | Joe Manuola"
  description="Learn about Joe Manuola — an accomplished technology leader with experience architecting scalable web applications and leading cross-functional engineering teams."
>
  <main class="mx-3">
    <div class="flex items-center justify-center overflow-hidden pt-12">
      <div class="flex max-w-6xl flex-col items-start gap-2 md:flex-row">
        <div class="clamp-[text,sm,xl] text-center leading-relaxed tracking-wider md:w-2xl md:text-left">
          <div class="clamp-[text,base,2xl] mb-3">
            <span class="font-extrabold">About</span>
          </div>
          <div class="mb-5">
            My excitement comes from guiding cross-functional teams to not just build things right, but to build the
            right things. For me, that means digging deep into business needs, architecting a clear technical strategy,
            and mentoring the talent that makes it all happen.
          </div>
          <div>
            I am a firm believer in continuous learning. My focus is on finding smarter ways to modernize products and
            streamline processes, not just on chasing new technology. In an industry defined by change, staying ahead of
            the curve is how I ensure solutions are technologically sound, drive real growth, and make life easier for
            the people who use them.
          </div>
          <section class="not-prose mt-4 flex flex-wrap items-center gap-x-2 text-[13px] text-gray-500">
            <a class="flex items-center gap-x-1.5 hover:text-gray-800" href="mailto:joe@manuola.com">
              <EmailIcon size={14} />joe@manuola.com
            </a>
            <span aria-hidden="true">|</span>
            <a class="flex items-center gap-x-1.5 hover:text-gray-800" href="https://linkedin.com/in/joemanuola">
              <LinkedInIcon size={14} />in/joemanuola
            </a>
            <span aria-hidden="true">|</span>
            <a class="flex items-center gap-x-1.5 hover:text-gray-800" href="https://github.com/PushLimits">
              <GithubIcon size={14} />PushLimits
            </a>
          </section>
        </div>
        <div class="flex w-full justify-center md:w-1/2">
          <Cards />
        </div>
      </div>
    </div>

    <div class="clamp-[text,4xl,5xl] text-primary mt-12 mb-6 text-center font-extrabold">
      What have I been working on all this time...
    </div>
    <div class="flex flex-wrap justify-center">
      <div
        class="bg-base-100 relative flex min-h-[6rem] max-w-4xl min-w-[18rem] flex-wrap items-center justify-center gap-2 overflow-x-hidden bg-cover bg-top p-4 xl:py-10"
      >
        <Timeline entries={timelineEntries} />
      </div>
    </div>
  </main>
</BaseLayout>
